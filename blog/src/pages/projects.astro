---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import PageHero from "@/components/PageHero.astro";
import { projects } from "@/data/projects";
import Breadcrumb from "@/components/Breadcrumb.astro";
---

<Layout title="Projetos" description="Projetos que desenvolvi ao longo da minha jornada como desenvolvedor.">
  <Header />
<Breadcrumb />
  <main id="main-content" class="app-layout pb-4">
    <PageHero
      title="Projetos"
      subtitle="Uma seleção dos projetos que desenvolvi e estudos que fiz."
    />

    <!-- ═══════════════════ DIVIDER ═══════════════════ -->
    <div class="mb-8 flex items-center gap-3">
      <div class="h-px flex-1 bg-border/20"></div>
      <span class="font-cartograph text-xs text-accent/40 select-none">[{projects.length} projetos]</span>
    </div>

    <!-- ═══════════════════ GRID ═══════════════════ -->
    <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 [&>li]:my-0 pb-16">
      {projects.map(project => (
        <ProjectCard {...project} />
      ))}
    </ul>
  </main>

  <Footer />
</Layout>

<script>
  let projectsCleanup: AbortController | null = null;

  document.addEventListener("astro:page-load", () => {
    if (projectsCleanup) projectsCleanup.abort();
    projectsCleanup = new AbortController();
    const { signal } = projectsCleanup;

    document.querySelectorAll<HTMLElement>(".project-card").forEach(card => {
      card.addEventListener("mousemove", (e: MouseEvent) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--mouse-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--mouse-y", `${e.clientY - rect.top}px`);
      }, { signal });
    });
  });
</script>
