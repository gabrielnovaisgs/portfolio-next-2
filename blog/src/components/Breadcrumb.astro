---
// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `Posts (page ${breadcrumbList[1] || 1})`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : "(page " + breadcrumbList[2] + ")"}`
  );
}
---

<nav class="app-layout mt-6 mb-2" aria-label="breadcrumb">
  <div
    class="inline-flex flex-wrap items-baseline gap-x-[0.1em] font-cartograph text-sm backdrop-blur-sm [-webkit-backdrop-filter:blur(4px)]"
  >
    <!-- user@host — links to home -->
    <a
      href="/"
      class="font-semibold text-accent transition-opacity duration-200 hover:opacity-75 filter-[drop-shadow(0_0_6px_color-mix(in_oklab,var(--color-accent)_40%,transparent))]"
      aria-label="Início"
      title="Início"
    >
      gabriel@novais
    </a>

    <!-- colon separator -->
    <span class="text-foreground opacity-40" aria-hidden="true">:</span>

    <!-- tilde root -->
    <span class="font-medium text-border">~</span>

    {
      breadcrumbList.map((breadcrumb, index) => (
        <>
          <span class="text-accent/40" aria-hidden="true">
            /
          </span>

          {index + 1 === breadcrumbList.length ? (
            <span
              class="max-w-[28ch] truncate capitalize text-accent/90"
              aria-current="page"
            >
              {decodeURIComponent(breadcrumb)}
            </span>
          ) : (
            <a
              href={`/${breadcrumb}/`}
              class="capitalize text-foreground/50 transition-colors duration-200 hover:text-accent"
            >
              {decodeURIComponent(breadcrumb)}
            </a>
          )}
        </>
      ))
    }
  </div>
</nav>
