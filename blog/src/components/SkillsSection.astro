---
import { STACK } from "@/data/stack";
---

<section class="skills-section relative mt-2 pb-16" id="skills" aria-label="Skills">
  <!-- Terminal-style header -->
  <header class="relative z-10 mb-6">
    <div
      class="mb-2 inline-flex flex-wrap items-baseline gap-x-[0.3em] font-cartograph text-[0.85rem] leading-none"
      aria-hidden="true"
    >
      <span
        class="font-semibold text-accent filter-[drop-shadow(0_0_6px_color-mix(in_oklab,var(--color-accent)_40%,transparent))]"
        >gabriel@novais</span
      ><span class="opacity-40 text-foreground">:</span><span class="font-medium text-border"
        >~/portfolio</span
      ><span class="ml-[0.1em] opacity-50 text-foreground">$</span>
      <span class="opacity-85 text-foreground"
        >skills <span class="opacity-70 text-border">--list</span></span
      >
      <span class="prompt-cursor text-accent">▊</span>
    </div>
    <p class="font-cartograph text-[0.85rem] tracking-wide opacity-45">
      Tecnologias que utilizo no dia a dia
    </p>
  </header>

  <!-- Categories grid -->
  <div class="relative z-10 grid grid-cols-2 gap-3.5 max-[540px]:grid-cols-1">
    {
      STACK.map((category, ci) => (
        <div
          class="skills-panel rounded-[0.875rem] border p-5 backdrop-blur-sm transition-[border-color,box-shadow] duration-300 hover:border-accent/20"
          style={`--ci: ${ci}; background: color-mix(in srgb, var(--color-foreground) 2.5%, var(--color-background)); border-color: color-mix(in srgb, var(--color-foreground) 7%, transparent); animation-delay: calc(${ci} * 80ms + 100ms)`}
        >
          <!-- Panel header -->
          <div class="mb-4 flex items-center gap-1.5 font-cartograph text-xs">
            <span class="font-bold text-accent/60">[</span>
            <span class="text-[0.7rem] font-semibold uppercase tracking-[0.04em]">
              {category.label}
            </span>
            <span class="font-bold text-accent/60">]</span>
            <span class="ml-0.5 text-[0.65rem] opacity-30">{category.techs.length}</span>
            <div class="ml-1 h-px flex-1 bg-linear-to-r from-accent/25 to-transparent" />
          </div>

          <!-- Tech chips -->
          <div class="flex flex-wrap gap-2">
            {category.techs.map((tech, ti) => (
              <div
                class="skills-chip group/chip relative inline-flex cursor-default items-center gap-1.5 overflow-hidden rounded-lg border px-2.5 py-1.5"
                style={`--tc: ${tech.color}; animation-delay: calc(${ti} * 40ms + 250ms); border-color: color-mix(in srgb, var(--color-foreground) 8%, transparent); background: color-mix(in srgb, var(--color-foreground) 3%, transparent)`}
                title={tech.name}
              >
                <!-- Brand-color glow (must stay CSS — uses --tc radial-gradient) -->
                <div class="chip-glow" />

                <!-- Icon -->
                <img
                  src={tech.icon}
                  alt=""
                  class:list={[
                    "relative z-10 size-4.5 shrink-0 object-contain",
                    tech.invertOnDark && "dark:invert dark:brightness-[0.85]",
                  ]}
                  width="18"
                  height="18"
                  loading="lazy"
                  aria-hidden="true"
                />

                <!-- Name -->
                <span class="relative z-10 whitespace-nowrap font-cartograph text-[0.75rem] font-medium tracking-wide opacity-80 transition-opacity duration-200 group-hover/chip:opacity-100">
                  {tech.name}
                </span>

                <!-- Bottom accent line (real element — background uses --tc inline) -->
                <div
                  class="absolute bottom-0 left-[15%] right-[15%] h-px rounded-full opacity-0 transition-opacity duration-200 group-hover/chip:opacity-70"
                  style={`background: var(--tc); box-shadow: 0 0 6px var(--tc)`}
                />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* Dot-grid pseudo-element — can't be expressed in Tailwind */
  .skills-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-foreground) 10%, transparent) 1px,
      transparent 1px
    );
    background-size: 22px 22px;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    z-index: 0;
  }

  /* Keyframe animations */
  @keyframes panel-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes chip-in {
    from { opacity: 0; transform: scale(0.9); }
    to   { opacity: 1; transform: scale(1); }
  }

  @keyframes cursor-blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  .skills-panel {
    opacity: 0;
    animation: panel-in 0.45s ease forwards;
  }

  .skills-chip {
    animation: chip-in 0.35s ease both;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }

  /* Brand-color hover — uses --tc, can't do in Tailwind */
  .skills-chip:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--tc, #888) 35%, transparent) !important;
    box-shadow:
      0 4px 16px -4px color-mix(in srgb, var(--tc, #888) 25%, transparent),
      0 0 0 1px color-mix(in srgb, var(--tc, #888) 10%, transparent);
  }

  .skills-chip:hover .chip-glow {
    opacity: 1;
  }

  /* Radial glow orb — uses --tc, can't do in Tailwind */
  .chip-glow {
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--tc, #888) 35%, transparent),
      transparent 65%
    );
    filter: blur(10px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .prompt-cursor {
    animation: cursor-blink 1.1s step-end infinite;
    filter: drop-shadow(0 0 4px color-mix(in oklab, var(--color-accent) 50%, transparent));
  }
</style>
