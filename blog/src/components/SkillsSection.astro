---
import { STACK } from "@/data/stack";
---

<section class="skills-section" id="skills" aria-label="Skills">
  <!-- Terminal-style header -->
  <header class="skills-header">
    <div class="skills-prompt-line" aria-hidden="true">
      <span class="prompt-user">gabriel@novais</span><span class="prompt-sep">:</span><span
        class="prompt-path">~/portfolio</span
      ><span class="prompt-dollar">$</span>
      <span class="prompt-cmd">skills <span class="prompt-flag">--list</span></span>
      <span class="prompt-cursor">▊</span>
    </div>
    <p class="skills-subtitle">Tecnologias que utilizo no dia a dia</p>
  </header>

  <!-- Categories grid -->
  <div class="skills-grid">
    {
      STACK.map((category, ci) => (
        <div class="category-panel" style={`--ci: ${ci}`}>
          <!-- Panel header -->
          <div class="category-header">
            <span class="cat-bracket">[</span>
            <span class="cat-label">{category.label}</span>
            <span class="cat-bracket">]</span>
            <span class="cat-count">{category.techs.length}</span>
            <div class="cat-line" />
          </div>

          <!-- Tech chips -->
          <div class="techs-wrap">
            {category.techs.map((tech, ti) => (
              <div
                class:list={["tech-chip", tech.invertOnDark && "tech-invert-dark"]}
                style={`--tc: ${tech.color}; --ti: ${ti}`}
                title={tech.name}
              >
                <div class="chip-glow" />
                <img
                  src={tech.icon}
                  alt=""
                  class="chip-icon"
                  width="18"
                  height="18"
                  loading="lazy"
                  aria-hidden="true"
                />
                <span class="chip-name">{tech.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  /* ── Section wrapper ───────────────────────────────────── */
  .skills-section {
    position: relative;
    margin-top: 0.5rem;
    padding-bottom: 4rem;
  }

  /* Dot-grid background */
  .skills-section::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: radial-gradient(
      circle,
      color-mix(in srgb, var(--color-foreground) 10%, transparent) 1px,
      transparent 1px
    );
    background-size: 22px 22px;
    pointer-events: none;
    mask-image: linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
    z-index: 0;
  }

  /* ── Prompt header ─────────────────────────────────────── */
  .skills-header {
    position: relative;
    z-index: 1;
    margin-bottom: 1.5rem;
  }

  .skills-prompt-line {
    display: inline-flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.3em;
    font-family: var(--font-cartograph);
    font-size: 0.85rem;
    line-height: 1;
    margin-bottom: 0.6rem;
  }

  .prompt-user {
    color: var(--color-accent);
    font-weight: 600;
    filter: drop-shadow(0 0 6px color-mix(in oklab, var(--color-accent) 40%, transparent));
  }

  .prompt-sep {
    color: var(--color-foreground);
    opacity: 0.4;
  }

  .prompt-path {
    color: var(--color-border);
    font-weight: 500;
  }

  .prompt-dollar {
    color: var(--color-foreground);
    opacity: 0.5;
    margin-left: 0.1em;
  }

  .prompt-cmd {
    color: var(--color-foreground);
    opacity: 0.85;
  }

  .prompt-flag {
    color: var(--color-border);
    opacity: 0.7;
  }

  .prompt-cursor {
    color: var(--color-accent);
    animation: cursor-blink 1.1s step-end infinite;
    filter: drop-shadow(0 0 4px color-mix(in oklab, var(--color-accent) 50%, transparent));
  }

  @keyframes cursor-blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .skills-subtitle {
    font-size: 0.85rem;
    color: var(--color-foreground);
    opacity: 0.45;
    font-family: var(--font-cartograph);
    letter-spacing: 0.01em;
  }

  /* ── Category grid ─────────────────────────────────────── */
  .skills-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.875rem;
  }

  @media (max-width: 540px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ── Category panel ────────────────────────────────────── */
  .category-panel {
    padding: 1.25rem;
    border-radius: 0.875rem;
    background: color-mix(in srgb, var(--color-foreground) 2.5%, var(--color-background));
    border: 1px solid color-mix(in srgb, var(--color-foreground) 7%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    animation: panel-in 0.45s ease forwards;
    animation-delay: calc(var(--ci, 0) * 80ms + 100ms);
    transition:
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .category-panel:hover {
    border-color: color-mix(in srgb, var(--color-accent) 20%, transparent);
    box-shadow: 0 4px 24px -8px color-mix(in srgb, var(--color-accent) 10%, transparent);
  }

  @keyframes panel-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Category header ───────────────────────────────────── */
  .category-header {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 1rem;
    font-family: var(--font-cartograph);
    font-size: 0.75rem;
  }

  .cat-bracket {
    color: var(--color-accent);
    font-weight: 700;
    opacity: 0.6;
  }

  .cat-label {
    color: var(--color-foreground);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .cat-count {
    color: var(--color-foreground);
    opacity: 0.3;
    font-size: 0.65rem;
    margin-left: 0.1rem;
  }

  .cat-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-accent) 25%, transparent),
      transparent
    );
    margin-left: 0.25rem;
  }

  /* ── Tech chips ────────────────────────────────────────── */
  .techs-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tech-chip {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.375rem 0.7rem 0.375rem 0.5rem;
    border-radius: 0.5rem;
    border: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
    background: color-mix(in srgb, var(--color-foreground) 3%, transparent);
    cursor: default;
    overflow: hidden;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
    animation: chip-in 0.35s ease both;
    animation-delay: calc(var(--ti, 0) * 40ms + 250ms);
  }

  @keyframes chip-in {
    from {
      opacity: 0;
      transform: scale(0.9);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  /* Brand-colored glow orb (mouse-follow on hover) */
  .chip-glow {
    position: absolute;
    inset: -30px;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--tc, #888) 35%, transparent), transparent 65%);
    filter: blur(10px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 0;
  }

  .tech-chip:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--tc, #888) 35%, transparent);
    box-shadow:
      0 4px 16px -4px color-mix(in srgb, var(--tc, #888) 25%, transparent),
      0 0 0 1px color-mix(in srgb, var(--tc, #888) 10%, transparent);
  }

  .tech-chip:hover .chip-glow {
    opacity: 1;
  }

  /* Colored accent line at bottom */
  .tech-chip::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 15%;
    right: 15%;
    height: 1.5px;
    border-radius: 999px;
    background: var(--tc, var(--color-accent));
    opacity: 0;
    transition: opacity 0.25s ease;
    box-shadow: 0 0 6px color-mix(in srgb, var(--tc, #888) 60%, transparent);
  }

  .tech-chip:hover::after {
    opacity: 0.7;
  }

  .chip-icon {
    position: relative;
    z-index: 1;
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex-shrink: 0;
  }

  /* Dark-mode inversion for black SVGs */
  :global(.dark) .tech-invert-dark .chip-icon {
    filter: invert(1) brightness(0.85);
  }

  .chip-name {
    position: relative;
    z-index: 1;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-foreground);
    opacity: 0.8;
    white-space: nowrap;
    transition: opacity 0.2s ease;
    font-family: var(--font-cartograph);
    letter-spacing: 0.01em;
  }

  .tech-chip:hover .chip-name {
    opacity: 1;
  }
</style>
